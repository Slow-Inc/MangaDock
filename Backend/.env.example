# ==============================
# Gemini AI  (translation)
# ==============================
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Story/description translation model settings
GEMINI_DESCRIPTION_MODEL=gemini-3-flash-preview
GEMINI_DESCRIPTION_FALLBACK_MODEL=gemini-2.5-flash

# Manga episode translation model settings
GEMINI_MANGA_MODEL=gemini-2.5-flash-lite
GEMINI_MANGA_FALLBACK_MODEL=gemini-2.5-flash-lite

# ==============================
# MangaDex
# ==============================
MANGADEX_LANG=th

# ==============================
# CORS
# ==============================
FRONTEND_ORIGIN=http://localhost:4000

# ==============================
# Server
# ==============================
PORT=4001

# ==============================
# Redis  (run: docker compose up -d)
# ==============================
REDIS_HOST=localhost
REDIS_PORT=6379

# ==============================
# Supabase (Auth + Database)
# ==============================
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ==============================
# Manga Image Translator (MIT)
# ==============================
# URL of the MIT server (Python FastAPI)
MANGA_TRANSLATOR_URL=http://localhost:5003

# Callback URL origin that MIT uses to call back into the backend after batch translation.
# When MIT and backend run on the same machine, set this to localhost so MIT can reach
# the backend directly without going through Cloudflare Tunnel (which would fail locally).
# In production (MIT on a separate host), leave unset to use BACKEND_PUBLIC_ORIGIN.
MIT_CALLBACK_ORIGIN=http://localhost:4001

# Set to "false" to NOT send the manga's original language (source_lang) to MIT.
# Useful when a chapter contains mixed languages and you want MIT to auto-detect.
# Default: true  → sends source_lang when available.
MIT_SEND_SOURCE_LANG=false

# ── MIT pipeline VRAM / performance knobs ────────────────────────────────────
# These tune the MIT config the backend sends per request. Detection and
# inpainting cost VRAM + time roughly proportional to size² — MIT's bundled
# defaults (detection 2560, inpainting 2048) are quality-tuned and heavier than
# most manga pages need. Lower them to fit smaller GPUs; raise for max quality.
# Leave unset to use the backend defaults shown below.
MIT_DETECTION_SIZE=2048          # text-detection resolution (MIT default 2560)
MIT_INPAINTING_SIZE=1536         # LaMa inpaint resolution (MIT default 2048)
MIT_INPAINTER=lama_large         # lama_large | lama_mpe | default — lama_mpe is lighter
MIT_INPAINTING_PRECISION=bf16    # fp32 | fp16 | bf16  (LaMa is a CNN: NO int4/int8)

# ==============================
# Image Cache  (local fallback)
# ==============================
# Set to "true" to download thumbnails + chapter pages into .cache/images/
# and serve them at /img-cache/* as a fallback when the upstream CDN is down.
# Leave unset or set to "false" when deploying serverless (e.g. Vercel).
IMAGE_CACHE_ENABLED=true

# Public origin of this backend, used when IMAGE_CACHE_ENABLED=true and
# forceLocal=true is requested (to build absolute /img-cache URLs).
# Defaults to http://localhost:{PORT} when unset.
BACKEND_PUBLIC_ORIGIN=http://localhost:4001

# ==============================
# Email Validation (optional)
# ==============================
# Free-tier friendly option: Abstract API
# Docs: https://www.abstractapi.com/email-verification-validation-api
# Set provider to "abstract" to enable, or leave unset/none to disable.
EMAIL_VALIDATION_PROVIDER=abstract
EMAIL_VALIDATION_API_KEY=your-abstract-api-key

# Timeout for the outbound validation request in milliseconds.
EMAIL_VALIDATION_TIMEOUT_MS=5000

# Cache validation results to preserve free-tier quota.
EMAIL_VALIDATION_CACHE_TTL_SEC=21600

# When true, sign-up continues if the external validation provider is unavailable.
EMAIL_VALIDATION_FAIL_OPEN=true

# Cloudflare Turnstile — CAPTCHA shown before manga chapter images load
# Get your site key from: https://dash.cloudflare.com → Turnstile → Add site
# Use "1x00000000000000000000AA" for always-pass testing locally
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
MIT_OCR_PROB=0.03


## Cloudflare Worker

WORKER_URL=your-worker-url
WORKER_SECRET=your-worker-secret-key
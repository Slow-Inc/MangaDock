# ── LLM (translation) ────────────────────────────────────────────────────────
# Provider: gemini (default) | openai | custom
# LLM_PROVIDER=gemini

# API key for all providers:
#   gemini  → Google AI Studio key (https://aistudio.google.com/apikey)
#   openai  → sk-...
#   custom  → any value accepted by your endpoint
# Upgrading? Rename GEMINI_API_KEY → LLM_API_KEY (old name still works but logs a deprecation warning)
LLM_API_KEY=

# Optional: override models per use-case
# Defaults when unset: gemini→gemini-2.5-flash / gemini-2.5-flash-lite, openai/custom→gpt-4o-mini
# LLM_DESCRIPTION_MODEL=gemini-2.5-flash
# LLM_MANGA_MODEL=gemini-2.5-flash-lite

# Required only for LLM_PROVIDER=custom (any OpenAI-compatible base URL)
# LLM_BASE_URL=http://localhost:11434/v1

# ==============================
# MangaDex
# ==============================
MANGADEX_LANG=th

# ==============================
# CORS
# ==============================
FRONTEND_URL=http://localhost:4000

# ==============================
# Server
# ==============================
PORT=4001

# ==============================
# Redis  (run: docker compose up -d)
# ==============================
REDIS_HOST=localhost
REDIS_PORT=6379

# ==============================
# Supabase (Auth + Database)
# ==============================
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Used by metrics /status health check
SUPABASE_ANON_KEY=

# ==============================
# Manga Image Translator (MIT)
# ==============================
# URL of the MIT server (Python FastAPI)
MANGA_TRANSLATOR_URL=http://localhost:5003

# Callback URL origin that MIT uses to call back into the backend after batch translation.
# When MIT and backend run on the same machine, set this to localhost so MIT can reach
# the backend directly without going through Cloudflare Tunnel (which would fail locally).
# In production (MIT on a separate host), leave unset to use BACKEND_PUBLIC_ORIGIN.
MIT_CALLBACK_ORIGIN=http://localhost:4001

# Set to "false" to NOT send the manga's original language (source_lang) to MIT.
# Useful when a chapter contains mixed languages and you want MIT to auto-detect.
# Default: true  → sends source_lang when available.
MIT_SEND_SOURCE_LANG=false

# Secret used to verify callbacks from MIT server (HMAC-SHA256)
MIT_WEBHOOK_SECRET=

# ==============================
# Image Cache  (local fallback)
# ==============================
# Set to "true" to download thumbnails + chapter pages into .cache/images/
# and serve them at /img-cache/* as a fallback when the upstream CDN is down.
# Leave unset or set to "false" when deploying serverless (e.g. Vercel).
IMAGE_CACHE_ENABLED=true

# Public origin of this backend, used when IMAGE_CACHE_ENABLED=true and
# forceLocal=true is requested (to build absolute /img-cache URLs).
# Defaults to http://localhost:{PORT} when unset.
BACKEND_PUBLIC_ORIGIN=http://localhost:4001

# ==============================
# Email Validation (optional)
# ==============================
# Free-tier friendly option: Abstract API
# Docs: https://www.abstractapi.com/email-verification-validation-api
# Set provider to "abstract" to enable, or leave unset/none to disable.
EMAIL_VALIDATION_PROVIDER=abstract
EMAIL_VALIDATION_API_KEY=

# Timeout for the outbound validation request in milliseconds.
EMAIL_VALIDATION_TIMEOUT_MS=5000

# Cache validation results to preserve free-tier quota.
EMAIL_VALIDATION_CACHE_TTL_SEC=21600

# When true, sign-up continues if the external validation provider is unavailable.
EMAIL_VALIDATION_FAIL_OPEN=true

# Cloudflare Turnstile — CAPTCHA shown before manga chapter images load
# Get your site key from: https://dash.cloudflare.com → Turnstile → Add site
# Use "1x00000000000000000000AA" for always-pass testing locally
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
MIT_OCR_PROB=0.03

# ── Render-parity (benchmark gap-closing #176/#179/#181) — dev defaults 2026-06-12 ──
# Graduated from opt-in knobs to dev defaults so EN output matches MangaTranslator:
# comic font + ALL-CAPS + bubble box-fit + 4x supersampling. Changes ALL translations
# (no longer byte-identical). SFX ぬ→LOOM (#168) still pending.
MIT_EN_COMIC_FONT=1          # #176: Latin/EN renders in comic shanns 2, not Prompt-Bold (Thai)
MIT_EN_FONT=anime_ace_3.ttf  # render fidelity: lighter Anime Ace face (matches the MangaTranslator target weight; overrides en_comic_font)
MIT_EN_UPPERCASE=1           # render-parity A: ALL-CAPS lettering
MIT_BUBBLE_SEG=1             # #170: speech-balloon YOLO masks
# MIT_BUBBLE_AREA_FIT=1      # OFF: fill-balloon sizing made dialogue too big/overlapping; small source-derived font matches the target
MIT_ANTI_OVERLAP=1           # anti-overlap text layout: clamp each region's box vs neighbours so text can't grow into the next bubble
MIT_CLEAN_LAYOUT=1           # render-layout rework: lay non-balloon/non-SFX text as an upright block at a small absolute font (no warp onto the vertical-JP quad → no stretch/overflow). Matches MangaTranslator.
MIT_FONT_SIZE_MAX=20         # clean_layout absolute font (px). With clean_layout ON this no longer backfires — the region returns before the legacy final_scale path.
MIT_SUPERSAMPLING=4          # #181: render 4x then downscale for crisp glyphs
# MIT_FONT_MAX_BOX_RATIO=0.5 # (only used when bubble_area_fit is on)
MIT_PATCH_FEATHER=16         # #173: feather outer 16px of each patch → seam blends into the page (no rectangle)
MIT_INPAINT_CONTEXT_PAD=256  # #249: inpaint a 256px-padded crop → LaMa FFC global branch sees real background (cleaner fill)
MIT_PATCH_FULLPAGE_INPAINT=1 # clean text removal: inpaint the WHOLE page once (full LaMa context) → patches reuse it; no per-crop gray blob over complex/dark art (matches upstream/target). Supersedes the per-crop context-pad for quality.
MIT_INPAINTER=flux_klein     # OFF (default lama_large). ADR 003 optional VRAM-neutral diffusion inpainter (Flux.2 Klein-4B Q4): reconstructs texture where LaMa leaves the band/ghost. Needs `diffusers`+`gguf` in MIT/.venv + a ~10GB one-time model download; ~3-4s/page vs LaMa <1s, so opt-in for max-quality runs. Switching this busts the patch cache (renderConfigHash).
# MIT_MASK_TIGHTEN=1          # OFF (#268): /debug-mantra — shrinking the mask under-erases → faint ghost of the ORIGINAL text remains everywhere it sat (worse than the band). Classical levers can't fix the band cleanly; the texture fix is Flux (optional inpainter).
# MIT_PATCH_CONTENT_ALPHA=1  # ROLLED BACK (#266): measured ineffective — band luminance unchanged (201.5→201.3) + caused text fading on dark bg. The real fix is luminance matching, not the patch-alpha shape.
MIT_SFX_DETECTOR=1           # #168: AnimeText SFX YOLO 2nd-pass detection (big stylized ぬ DBNet misses)
MIT_OCR_VLM_RESCUE=1         # #168: vision-LLM rescue — localize the big SFX crop to English (ぬ→SQUELCH); survives filter + inpaints original

# ==============================
# Xendit Payment Gateway
# ==============================
# Get keys from: https://dashboard.xendit.co → Settings → API Keys
# Use xnd_development_* for sandbox
XENDIT_SECRET_KEY=
# Set in Xendit Dashboard → Webhooks → Webhook Verification Token
XENDIT_WEBHOOK_TOKEN=
# Required for production HMAC signature verification on Xendit webhook callbacks
XENDIT_WEBHOOK_SECRET=

XENDIT_ALLOW_SIMULATE=true

## Cloudflare Worker / Storage backend

# Which storage backend serves uploaded assets (chapter pages, patches, avatars).
#   disk | local      → backend's local disk (./uploads, ./img-cache)
#   r2   | cloudflare  → Cloudflare R2 via the Worker (needs WORKER_URL + WORKER_SECRET)
# Leave UNSET to auto-detect: R2 when both worker creds below are set, local disk otherwise.
# Set to "disk" in development to force local storage even if R2 creds are present.
STORAGE_DRIVER=disk

## Cloudflare Worker
WORKER_URL=
WORKER_SECRET=

# Supabase
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend API
# Public URL — used by client-side code (baked into JS bundle at build time)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4001
# Internal URL — used by server-side proxy routes (Next.js → NestJS, server-to-server)
# Set this to localhost on VPS to avoid routing through Cloudflare Tunnel twice.
INTERNAL_API_URL=http://localhost:4001

# Dev Tools — set to "true" to show the img-cache test toggle (bottom-right button)
NEXT_PUBLIC_IMAGE_CACHE_DEV_TOOLS=false

# Dev HMR origins — add your Cloudflare Tunnel hostname (no protocol, comma-separated)
# so that Next.js Hot Module Replacement works without triggering full page reloads.
# Without this, accessing the dev server via a Tunnel causes periodic page refreshes.
NEXT_DEV_EXTRA_ORIGINS=hayateotsu.space

# Cloudflare Worker / R2 CDN
# URL of your Cloudflare Worker (e.g. https://mangadock-worker.yourname.workers.dev)
NEXT_PUBLIC_CF_WORKER_URL=
# Set to "true" to route all image requests through Cloudflare Worker instead of Backend Proxy
NEXT_PUBLIC_USE_CF_WORKER=false

# Cloudflare Turnstile — CAPTCHA shown before manga chapter images load
# Get your site key from: https://dash.cloudflare.com → Turnstile → Add site
# Use "1x00000000000000000000AA" for always-pass testing locally
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# GitHub API (Docs page — /docs)
# Personal Access Token for fetching issues, PRs, and branches.
# Without a token, GitHub allows 60 unauthenticated requests/hour.
# Create one at: https://github.com/settings/tokens (read:org scope enough for public repos)
GITHUB_TOKEN=
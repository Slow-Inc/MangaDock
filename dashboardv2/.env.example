# Copy to .env.local and fill in. Powers the AI chat + incident summary via an
# OpenAI-compatible gateway (the project uses 9arm, same as MIT). If unset, the
# AI panels fall back to the built-in mock answers.
LLM_BASE_URL=https://gateway.9arm.co/v1
LLM_API_KEY=
LLM_MODEL=qwen3.6-35b-a3b

# Supabase OAuth for the Dev-console login (PRD #279, ADR 016). Same project as
# the app Frontend; the publishable/anon key is public. If unset, the gate is
# bypassed and the dashboard runs on mock data.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# MIT status aggregator target (server-side). The /api/live proxy forwards the
# dev's Supabase JWT to MIT's /status/stream here; MIT verifies it independently.
MIT_STATUS_URL=http://127.0.0.1:5003

# Service-status probes (server-side — never exposed to browser).
# Defaults work for local dev; override for staging/prod.
FRONTEND_STATUS_URL=http://localhost:4000/status
BACKEND_STATUS_URL=http://localhost:3001/status

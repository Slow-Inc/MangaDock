# Environment file for the customized manga-image-translator service.
#
# Purpose:
# - This file is the shareable template version of the local runtime config.
# - Copy this file to `.env` before running the service.
#
# Usage:
# - Fill in only the providers you actually use.
# - Keep `.env` private and out of Git.
# - Commit this file instead of the real `.env`.

# Gemini (primary translator used by MangaDock)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# OpenAI / Custom OpenAI-compatible providers
OPENAI_API_KEY=
CUSTOM_OPENAI_API_BASE=http://localhost:11434/v1
CUSTOM_OPENAI_MODEL=

# DeepL
DEEPL_AUTH_KEY=

# Optional websocket/shared-mode secret when using ws mode
WS_SECRET=

# Qwen2 offline translator (requires GPU + transformers + bitsandbytes)
# QWEN2_MODEL=Qwen/Qwen2-1.5B-Instruct   # HuggingFace model ID
# QWEN2_4BIT=true                          # true = INT4 (~0.8GB VRAM), false = BF16 (~3GB VRAM)
# QWEN2_TORCH_DTYPE=auto                   # auto | bfloat16 | float16
# QWEN2_MAX_NEW_TOKENS=10240               # max output tokens per request

# Qwen2 Big (7B) — overrides above for qwen2_big translator key
# QWEN2_BIG_MODEL=Qwen/Qwen2-7B-Instruct
# QWEN2_BIG_4BIT=true                      # default true (7B ต้องการ 4-bit สำหรับ 6GB VRAM)
# ============================================================
# MIT — Manga Image Translator  |  environment config template
# ============================================================
# Copy this file to .env and fill in the values you need.
# Keep .env out of Git — commit only this file.
# ============================================================


# ── 1. TRANSLATOR SELECTION ──────────────────────────────────
#
# Step 1: choose type
#   api   = Third-Party API  (needs an API key below)
#   local = Local LLM        (needs a GPU + model weights)
#
TRANSLATOR_TYPE=api

# Step 2: choose the model for that type
#   api options:   gemini | deepseek | groq | custom_openai
#   local options: qwen3 (Qwen3.5-4B) | qwen3_big (Qwen3.5-8B) | qwen2 | nllb | sugoi
#
DEFAULT_API_TRANSLATOR=gemini
# DEFAULT_LOCAL_TRANSLATOR=qwen3


# ── 2. API KEYS (Third-Party translators) ────────────────────

# Gemini  →  get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# OpenAI / Ollama / any OpenAI-compatible endpoint
OPENAI_API_KEY=
CUSTOM_OPENAI_API_BASE=http://localhost:11434/v1
CUSTOM_OPENAI_MODEL=

# DeepL
DEEPL_AUTH_KEY=

# WebSocket shared-mode secret (ws mode only)
WS_SECRET=


# ── 3. HUGGINGFACE AUTH (required for Local LLM model download) ─────
#
# Get token: https://huggingface.co/settings/tokens  (Read permission)
# Paste token below — transformers reads HF_TOKEN automatically.
# Also accept model license at https://huggingface.co/Qwen/Qwen3.5-4B
# before first download.
#
# HF_TOKEN=hf_xxxxxxxxxxxxxxxx


# ── 4. LOCAL LLM CONFIG (only needed when TRANSLATOR_TYPE=local) ──
#
# Patch concurrency — max GPU groups processed in parallel during translate_patches
# Lower = less VRAM pressure; higher = faster on multi-core GPU
# PATCH_CONCURRENCY=3

# Qwen3.5  (4B)  — precision: fp8 | bf16 | fp16 | int8 | int4  (default: bf16)
#   VRAM:  fp8 ~4 GB  |  bf16 ~8 GB  |  fp16 ~8 GB  |  int8 ~4 GB  |  int4 ~2 GB
#   fp8 requires PyTorch >= 2.1 and Ada Lovelace GPU (RTX 40xx)
# QWEN3_MODEL=Qwen/Qwen3.5-4B
# QWEN3_PRECISION=fp8
# QWEN3_MAX_NEW_TOKENS=4096

# Qwen3.5 Big  (8B+) — inherits QWEN3_PRECISION if QWEN3_BIG_PRECISION not set
# QWEN3_BIG_MODEL=Qwen/Qwen3.5-8B
# QWEN3_BIG_PRECISION=fp8

# Qwen2  (1.5B — lighter option)
#   VRAM:  bf16 ~3 GB  |  int4 ~0.8 GB
# QWEN2_MODEL=Qwen/Qwen2-1.5B-Instruct
# QWEN2_PRECISION=bf16
# QWEN2_MAX_NEW_TOKENS=10240

# Qwen2 Big  (7B) — inherits QWEN2_PRECISION if QWEN2_BIG_PRECISION not set
# QWEN2_BIG_MODEL=Qwen/Qwen2-7B-Instruct
# QWEN2_BIG_PRECISION=int4
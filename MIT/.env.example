# ============================================================
# MIT — Manga Image Translator  |  environment config template
# ============================================================
# Copy this file to .env and fill in the values you need.
# Keep .env out of Git — commit only this file.
# ============================================================


# ── 1. TRANSLATOR SELECTION ──────────────────────────────────
#
# Step 1: choose type
#   api   = Third-Party API  (needs an API key below)
#   local = Local LLM        (needs a GPU + model weights)
#
TRANSLATOR_TYPE=api

# Step 2: choose the model for that type
#
#   api options (LLM, GPT-family — full feature set incl. series context #157):
#     gemini | gemini_2stage | chatgpt | chatgpt_2stage | deepseek | groq
#     | custom_openai (any OpenAI-compatible endpoint: Ollama, vLLM,
#       OpenRouter, LM Studio, ...)
#
#   api options (classic MT — no LLM prompting, no series context):
#     deepl | baidu | youdao | caiyun | papago (keyless) | sakura (local server)
#
#   local options: qwen3 (Qwen3.5-4B) | qwen3_big (Qwen3.5-8B)
#     | qwen2 | qwen2_big | nllb | nllb_big | sugoi
#     | jparacrawl | jparacrawl_big | m2m100 | m2m100_big | mbart50
#
DEFAULT_API_TRANSLATOR=gemini
# DEFAULT_LOCAL_TRANSLATOR=qwen3


# ── 2. API KEYS (Third-Party translators) ────────────────────
# Fill in only the key(s) for the translator you selected above.

# Gemini  →  get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# ChatGPT / OpenAI  (translator: chatgpt)
# OPENAI_API_BASE also accepts any OpenAI-compatible URL.
OPENAI_API_KEY=
# OPENAI_MODEL=chatgpt-4o-latest
# OPENAI_API_BASE=https://api.openai.com/v1

# DeepSeek  (translator: deepseek)
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_API_BASE=https://api.deepseek.com

# Groq  (translator: groq)
# GROQ_API_KEY=
# GROQ_MODEL=mixtral-8x7b-32768

# Custom OpenAI-compatible endpoint  (translator: custom_openai)
# Zero-code path for any provider speaking the OpenAI API
# (Ollama, vLLM, OpenRouter, LM Studio, ...).
# CUSTOM_OPENAI_API_KEY=ollama
CUSTOM_OPENAI_API_BASE=http://localhost:11434/v1
CUSTOM_OPENAI_MODEL=

# Together AI  (used by the *_2stage translators for the vision pass)
# TOGETHER_API_KEY=
# TOGETHER_VL_MODEL=Qwen/Qwen2.5-VL-72B-Instruct

# DeepL  (translator: deepl)
DEEPL_AUTH_KEY=

# Baidu  (translator: baidu)
# BAIDU_APP_ID=
# BAIDU_SECRET_KEY=

# Youdao  (translator: youdao)
# YOUDAO_APP_KEY=
# YOUDAO_SECRET_KEY=

# Caiyun  (translator: caiyun)
# CAIYUN_TOKEN=

# Sakura  (translator: sakura — self-hosted API server)
# SAKURA_API_BASE=http://localhost:8080/v1
# SAKURA_VERSION=0.9

# WebSocket shared-mode secret (ws mode only)
WS_SECRET=


# ── 3. HUGGINGFACE AUTH (required for Local LLM model download) ─────
#
# Get token: https://huggingface.co/settings/tokens  (Read permission)
# Paste token below — transformers reads HF_TOKEN automatically.
# Also accept model license at https://huggingface.co/Qwen/Qwen3.5-4B
# before first download.
#
# HF_TOKEN=hf_xxxxxxxxxxxxxxxx


# ── 4. LOCAL LLM CONFIG (only needed when TRANSLATOR_TYPE=local) ──
#
# Patch concurrency — max GPU groups processed in parallel during translate_patches
# Lower = less VRAM pressure; higher = faster on multi-core GPU
PATCH_CONCURRENCY=3

# Qwen3.5  (4B)  — precision: fp8 | bf16 | fp16 | int8 | int4  (default: bf16)
#   VRAM:  fp8 ~4 GB  |  bf16 ~8 GB  |  fp16 ~8 GB  |  int8 ~4 GB  |  int4 ~2 GB
#   fp8 requires PyTorch >= 2.1 and Ada Lovelace GPU (RTX 40xx)
#
#   RECOMMENDED per GPU (translation quality loss at int4/NF4 is negligible for a
#   4B instruct model — the sentences are short, so quantization barely shows):
#     ≥16 GB           → bf16 (max quality headroom)
#     RTX 40xx ≤12 GB  → fp8  (native, fastest at low VRAM)
#     8–12 GB (no fp8) → int4 (~2 GB, frees VRAM for the detector/OCR/inpainter)
#     <8 GB            → int4, or switch to Qwen2 1.5B int4 (~0.8 GB) below
# QWEN3_MODEL=Qwen/Qwen3.5-4B
# QWEN3_PRECISION=int4
# QWEN3_MAX_NEW_TOKENS=4096

# Qwen3.5 Big  (8B+) — inherits QWEN3_PRECISION if QWEN3_BIG_PRECISION not set
# QWEN3_BIG_MODEL=Qwen/Qwen3.5-8B
# QWEN3_BIG_PRECISION=fp8

# Qwen2  (1.5B — lighter option)
#   VRAM:  bf16 ~3 GB  |  int4 ~0.8 GB
# QWEN2_MODEL=Qwen/Qwen2-1.5B-Instruct
# QWEN2_PRECISION=bf16
# QWEN2_MAX_NEW_TOKENS=10240

# Qwen2 Big  (7B) — inherits QWEN2_PRECISION if QWEN2_BIG_PRECISION not set
# QWEN2_BIG_MODEL=Qwen/Qwen2-7B-Instruct
# QWEN2_BIG_PRECISION=int4


# ── 5. RESULT FILE MANAGEMENT (security — Issue #102) ───────
#
# The /results/clear endpoint deletes ALL stored result directories.
# It has no path-traversal risk (only iterates RESULT_ROOT) but is
# unauthenticated and bulk-destructive. Disabled by default.
# Enable only on a standalone dev instance with the web UI.
#
# MIT_ENABLE_RESULT_CLEAR=0


# ── 6. WEBHOOK DELIVERY (batch translation callbacks) ────────
#
# After translating each page in a batch, MIT POSTs the result to the Backend.
# Transient failures (5xx / 429 / connection error) are retried with exponential
# backoff; non-retryable 4xx and exhausted budgets are logged as a dead-letter.
#
# Retries after the first attempt (default 3 -> 4 attempts total)
# MIT_WEBHOOK_MAX_RETRIES=3
# Base backoff in ms; doubles each retry (500 -> 0.5s, 1s, 2s)
# MIT_WEBHOOK_RETRY_BACKOFF_MS=500


# ── 7. CROSS-PAGE ROLLING CONTEXT (P2 / #159 / #524) ─────────
#
# Recent pages' translated dialogue seeds the next page's prompt for name/pronoun/
# honorific consistency across a chapter. Born and dies with the batch loop (the
# worker still resets per request, so the #136 cross-job bleed class stays impossible).
#
# 0 (default) = OFF, byte-identical. To ENABLE, set this on BOTH the MIT worker AND
# the Backend process: MIT builds the context; the Backend must know to send the FULL
# ordered chapter on a partial-cache batch (else the #524 cache-safety hole reopens —
# a context-free page cached under a context-on key). Flipping it busts the patch cache
# once. Enable only AFTER the P7 numbered-contract + determinism gate (a hallucinated
# line would otherwise bleed into later pages' prompts). See ADR 010.
#
# MIT_CONTEXT_PAGES=3
# Char cap on the rendered prior-context block (oldest lines dropped first)
# MIT_CONTEXT_MAX_CHARS=1500
